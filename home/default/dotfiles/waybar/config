{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "height": 34,
    "spacing": 4,

    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "custom/gpu",
        "memory",
        "pulseaudio",
        "network",
        "battery",
        "tray",
        "mpris"
    ],

    "custom/launcher": {
        "format": "َ±„…",
        "on-click": "rofi -show drun",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{name}",
        "all-outputs": true,
        "sort-by-number": true,
        "format-icons": {
            "active": "َ°®¯",
            "default": "َ°ٹ "
        }
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 40,
        "separate-outputs": true
    },

    "clock": {
        "format": "{:%I:%M %p | %a %d}",
        "tooltip": false,
        "on-click": "ags toggle dashboard"
    },

    "cpu": {
        "format": "َ°»  {usage}%",
        "interval": 2,
        "tooltip": true,
        "tooltip-format": "{usage}%"
    },

    "custom/gpu": {
        "format": "{}",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scripts/gpu-usage.sh",
        "interval": 2,
        "tooltip": true
    },

    "memory": {
        "format": "َ°چ› {percentage}%",
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں Muted",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol",
        "tooltip": false
    },

    "network": {
        "format-wifi": "َ°¤¨ {essid}",
        "format-ethernet": "َ°ˆ€ Wired",
        "format-disconnected": "َ°¤­ None",
        "tooltip": false,
        "on-click": "wl-copy $(ip addr show | grep 'inet ' | grep -v '127.0.0.1' | awk '{print $2}' | cut -d/ -f1 | head -1) && notify-send 'َ°ˆ€ IP Copied' \"$(ip addr show | grep 'inet ' | grep -v '127.0.0.1' | awk '{print $2}' | cut -d/ -f1 | head -1)\""
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip": false
    },

    "mpris": {
        "format": "{player_icon} {title}",
        "format-paused": "{player_icon} {title}",
        "player-icons": {
            "default": "",
            "spotify": ""
        },
        "status-icons": {
            "paused": ""
        },
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-scroll-up": "playerctl previous",
        "on-scroll-down": "playerctl next",
        "max-length": 30,
        "tooltip": false
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    }
}
